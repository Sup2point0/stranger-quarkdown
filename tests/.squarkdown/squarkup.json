{
  "$schema": "../../squarkdown/resources/squarkup-schema.json",

  "repo": "Squarkdown Tests",

  "paths / site": "tests/test-site",
  "paths / exclude": [
    "/_.*?\\.md",
    "/-.*?\\.md"
  ],
  "paths / dest": "export/routes/",

  "opts / on-error": "kill",
  "opts / on-no-dir": ["warn", "create"],

  "bases / path": "resources/",
  "bases / page.svelte": "test.svelte",
  
  "styles / path": "src/styles/",
  "styles / page-styles": "src/styles/",

  "assets / path": ".assets",
  "assets / site-assets": ".assets/site",
  "assets / extensions": [
    "png",
    "svg"
  ],

  "fonts / queries": ["Test Sans"]
}
