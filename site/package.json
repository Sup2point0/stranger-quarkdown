{
	"name": "squarkdown",
	"version": "1.0",
	"private": true,
  "type": "module",

	"scripts": {
		"dev": "vite",
      "devx": "npm run prep && vite --open",
		
    "prep": "npm run squark",
      "prepx": "npm run squarkx && rake schema",
		
    "squark": "cd .. && rake squark[fonts,scss,--root] && cd site",
      "squarkx": "cd .. && bundle exec rake squark[fonts,scss,assets,--root] && cd site",
		
    "build": "vite build",
      "buildx": "npm run prepx && vite build",
		
    "preview": "vite preview"
	},
  
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0",
		"@sveltejs/kit": "^2.69",
		"@sveltejs/vite-plugin-svelte": "^7.2",
		"mdsvex": "^0.12.6",
		"rehype-autolink-headings": "7.1.0",
    "rehype-slug": "6.0.0",
		"remark-footnotes": "2.0.0",
		"remark-numbered-footnote-labels": "1.1.0",
		"sass": "^1.101",
		"svelte": "^5.56",
		"svelte-preprocess": "^6.0",
		"tslib": "^2.8",
		"typescript": "^5.0",
    "unist-util-visit": "^5.0.0",
		"vite": "^8.1"
	}
}
